# ── Data and Jupyter Notebooks ──
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
*.csv
*.json
!app/schemas.py  # Explicitly ensure your schema file isn't accidentally ignored if you use broad rules

# ── Machine Learning Artifacts ──
# Ignore large model files globally to prevent repository bloating...
*.h5
*.onnx
*.pb
*.pt
*.pth

# ...BUT explicitly track your project's specific scikit-learn models
# This ensures scaler.pkl, model_productivity.pkl, model_quality.pkl, and feature_cols.pkl are saved!
!models/*.pkl